<?php

namespace App\Http\Controllers;

use App\Events\IssueCreated;
use App\Events\IssueStatusUpdated;
use App\Models\Lead;
use App\Models\LeadIssue;
use App\Models\IssueAttachment;
use App\Models\User;
use App\Notifications\IssueCreatedNotification;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Schema;
use Illuminate\Support\Facades\Storage;
use Illuminate\Support\Str;

class LeadIssueController extends Controller
{
    /**
     * Report Manager portal list with filters, search, and per-status counts.
     */
    public function index(Request $request)
    {
        $this->authorize('viewAny', LeadIssue::class);

        $query = LeadIssue::with(['lead', 'reporter', 'assignedTo'])->latest();

        if ($s = $request->get('status')) {
            $query->where('status', $s);
        }
        if ($p = $request->get('priority')) {
            $query->where('priority', $p);
        }
        if ($a = $request->get('assigned_to')) {
            $query->where('assigned_to', $a);
        }
        if ($q = trim((string) $request->get('q'))) {
            $query->where(function ($x) use ($q) {
                $x->where('title', 'like', "%{$q}%")
                    ->orWhere('description', 'like', "%{$q}%");
            });
        }

        // Status counts for quick tabs
        $counts = LeadIssue::selectRaw('status, COUNT(*) as c')
            ->groupBy('status')
            ->pluck('c', 'status');

        $issues = $query->paginate(20)->withQueryString();
        $managers = User::whereHas('roles', function($q) {
            $q->where('name', 'report_manager');
        })->get();

        return view('issues.index', compact('issues', 'counts', 'managers'));
    }

    /**
     * Detail view for an issue (status, priority, comments, attachments).
     */
    public function show(LeadIssue $issue)
    {
        $this->authorize('view', $issue);

        $issue->load(['reporter', 'lead', 'assignedTo', 'attachments.uploader']);
        $comments = $issue->comments()
            ->with('author')
            ->latest()
            ->take(50)
            ->get()
            ->reverse();

        $managers = User::whereHas('roles', function($q) {
            $q->where('name', 'report_manager');
        })->get();

        return view('issues.show', compact('issue', 'comments', 'managers'));
    }

    /**
     * Store a new issue.
     */
    public function store(Request $request, Lead $lead)
    {
        $this->authorize('create', [LeadIssue::class, $lead]);

        $data = $request->validate([
            'title' => 'required|string|max:160',
            'priority' => 'required|in:low,medium,high,urgent',
            'description' => 'required|string|max:5000',
            'due_date' => 'nullable|date',
            'assigned_to' => 'nullable|exists:users,id',
        ]);

        DB::transaction(function() use ($data, $lead, $request) {
            $issue = LeadIssue::create([
                'lead_id' => $lead->id,
                'reporter_id' => $request->user()->id,
                'assigned_to' => $data['assigned_to'],
                'title' => $data['title'],
                'priority' => $data['priority'],
                'description' => $data['description'],
                'due_date' => $data['due_date'],
                'status' => 'open'
            ]);

            // Handle file attachments if any
            if ($request->hasFile('attachments')) {
                foreach ($request->file('attachments') as $file) {
                    $path = $file->store('issue-attachments');
                    
                    IssueAttachment::create([
                        'issue_id' => $issue->id,
                        'uploader_id' => $request->user()->id,
                        'filename' => $file->getClientOriginalName(),
                        'path' => $path,
                        'size' => $file->getSize(),
                        'mime_type' => $file->getMimeType()
                    ]);
                }
            }

            // Notify report managers
            User::role('report_manager')->get()
                ->each(fn($user) => $user->notify(new IssueCreatedNotification($issue)));
        });
                'priority' => $data['priority'],
                'description' => $data['description'],
                'due_date' => $data['due_date'],
                'status' => LeadIssue::STATUS_OPEN,
            ]);

            event(new IssueCreated($issue));

            // Notify assigned manager if one was selected
            if ($issue->assigned_to) {
                $issue->assignedTo->notify(new IssueCreatedNotification($issue));
            }

            return $issue;
        });

        return redirect()->route('leads.show', $lead)
            ->with('success', 'Issue reported successfully.');

            }

    /**
     * Update issue status and other fields
     */
    public function update(Request $request, LeadIssue $issue)
    {
        $this->authorize('update', $issue);

        $data = $request->validate([
            'status' => 'sometimes|required|in:open,in_progress,resolved,closed',
            'priority' => 'sometimes|required|in:low,medium,high,urgent',
            'assigned_to' => 'sometimes|nullable|exists:users,id',
            'due_date' => 'sometimes|nullable|date',
            'resolution' => 'required_if:status,resolved|nullable|string|max:5000',
        ]);

        $oldStatus = $issue->status;

        if (isset($data['status']) && $data['status'] === 'resolved') {
            $data['resolution_date'] = now();
        }

        $issue->update($data);

        if (isset($data['status']) && $data['status'] !== $oldStatus) {
            event(new IssueStatusUpdated($issue, $oldStatus));
        }

        return back()->with('success', 'Issue updated successfully.');
    }

    /**
     * Upload attachments to an issue
     */
    public function attachFiles(Request $request, LeadIssue $issue)
    {
        $this->authorize('update', $issue);

        $request->validate([
            'attachments' => 'required|array',
            'attachments.*' => 'required|file|max:10240', // 10MB max per file
        ]);

        foreach ($request->file('attachments') as $file) {
            $fileName = $file->getClientOriginalName();
            $path = $file->storeAs(
                "issues/{$issue->lead_id}/{$issue->id}",
                Str::random(40) . '_' . $fileName,
                'public'
            );

            IssueAttachment::create([
                'lead_issue_id' => $issue->id,
                'uploaded_by' => $request->user()->id,
                'file_name' => $fileName,
                'file_path' => $path,
                'mime_type' => $file->getMimeType(),
                'file_size' => $file->getSize(),
            ]);
        }

        return back()->with('success', 'Files uploaded successfully.');
    }

    /**
     * Download an issue attachment
     */
    public function downloadAttachment(IssueAttachment $attachment)
    {
        $this->authorize('view', $attachment->issue);

        return Storage::disk('public')->download(
            $attachment->file_path,
            $attachment->file_name
        );
    }

    /**
     * Delete an issue attachment
     */
    public function deleteAttachment(IssueAttachment $attachment)
    {
        $this->authorize('update', $attachment->issue);

        Storage::disk('public')->delete($attachment->file_path);
        $attachment->delete();

        return back()->with('success', 'Attachment deleted successfully.');
    }
}
        User::whereIn('role', ['report_manager', 'admin'])
            ->each(fn($u) => $u->notify(new IssueCreatedNotification($issue)));

        // ✅ Realtime broadcast
        event(new IssueCreated($issue));

        return back()->with('success', 'Issue submitted. The report team has been notified.');
    }

    /**
     * Report manager/admin updates status (broadcasts in real time).
     */
    public function updateStatus(Request $request, LeadIssue $issue)
    {
        $this->authorize('update', $issue);

        $data = $request->validate([
            'status' => 'required|in:open,triaged,in_progress,resolved,closed',
        ]);

        $from = $issue->status;
        $issue->update($data);

        // Optional: audit event
        $this->logEvent($issue->id, $request->user()->id, 'status_changed', [
            'from' => $from,
            'to'   => $issue->status,
        ]);

        // Broadcast to managers presence channel and private issue channel
        event(new IssueStatusUpdated($issue));

        return back()->with('success', 'Status updated.');
    }

    /**
     * Report manager/admin updates priority (no broadcast needed, but you can add one).
     */
    public function updatePriority(Request $request, LeadIssue $issue)
    {
        $this->authorize('update', $issue);

        $data = $request->validate([
            'priority' => 'required|in:low,normal,high,urgent',
        ]);

        $issue->update($data);

        // Optional: audit event
        $this->logEvent($issue->id, $request->user()->id, 'priority_changed', [
            'to' => $issue->priority,
        ]);

        return back()->with('success', 'Priority updated.');
    }

    /**
     * Lightweight helper to log into issue_events if the table exists.
     */
    protected function logEvent(int $issueId, int $actorId, string $type, array $meta = []): void
    {
        if (!Schema::hasTable('issue_events')) {
            return;
        }
        DB::table('issue_events')->insert([
            'lead_issue_id' => $issueId,
            'actor_id'      => $actorId,
            'type'          => $type,
            'meta'          => $meta ? json_encode($meta) : null,
            'created_at'    => now(),
            'updated_at'    => now(),
        ]);
    }
}
